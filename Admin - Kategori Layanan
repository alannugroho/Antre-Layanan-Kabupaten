<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kategori Layanan - Admin Panel</title>
    
    <!-- Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Icons: FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Tailwind Config -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        primary: {
                            DEFAULT: '#0056B3', 
                            dark: '#004494',
                            light: '#E0F2FE',
                        },
                        neutral: {
                            bg: '#F8F9FA',
                            sidebar: '#0f172a',
                            text: '#374151',
                            heading: '#111827',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        .modal { transition: opacity 0.25s ease; }
        body.modal-active { overflow: hidden; }
        .nav-item.active {
            background-color: rgba(255, 255, 255, 0.1);
            border-left: 4px solid #38bdf8;
            color: white;
        }
        /* Custom Checkbox Toggle */
        .toggle-checkbox:checked {
            right: 0;
            border-color: #0056B3;
        }
        .toggle-checkbox:checked + .toggle-label {
            background-color: #0056B3;
        }
    </style>
</head>
<body class="bg-neutral-bg h-screen flex overflow-hidden font-sans text-neutral-text">

    <!-- 1. SIDEBAR (Consistent) -->
    <aside class="w-64 bg-primary-dark text-white flex flex-col shadow-2xl z-20 shrink-0">
        <div class="h-16 flex items-center gap-3 px-6 border-b border-white/10 bg-primary">
            <div class="w-8 h-8 bg-white/20 rounded flex items-center justify-center">
                <i class="fa-solid fa-layer-group text-white text-sm"></i>
            </div>
            <span class="font-bold text-lg tracking-wide">Admin Panel</span>
        </div>

        <nav class="flex-1 py-6 px-3 space-y-1 overflow-y-auto">
            <p class="px-3 text-xs font-semibold text-blue-200/50 uppercase tracking-wider mb-2">Utama</p>
            
            <a href="admin_panel.html" class="nav-item flex items-center gap-3 px-4 py-3 text-sm font-medium text-blue-100 hover:bg-white/5 hover:text-white rounded-r-lg transition-colors">
                <i class="fa-solid fa-chart-pie w-5"></i>
                Dashboard
            </a>
            
            <a href="admin_users.html" class="nav-item flex items-center gap-3 px-4 py-3 text-sm font-medium text-blue-100 hover:bg-white/5 hover:text-white rounded-r-lg transition-colors">
                <i class="fa-solid fa-users w-5"></i>
                Manajemen Akun
            </a>
            
            <!-- Active State -->
            <a href="#" class="nav-item active flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-r-lg transition-colors">
                <i class="fa-solid fa-tags w-5"></i>
                Kategori Layanan
            </a>

            <p class="px-3 text-xs font-semibold text-blue-200/50 uppercase tracking-wider mb-2 mt-6">Data & Arsip</p>

            <a href="#" class="nav-item flex items-center gap-3 px-4 py-3 text-sm font-medium text-blue-100 hover:bg-white/5 hover:text-white rounded-r-lg transition-colors">
                <i class="fa-solid fa-file-invoice w-5"></i>
                Laporan Antrean
            </a>
        </nav>

        <div class="p-4 border-t border-white/10 bg-black/10">
            <a href="login.html" class="flex items-center gap-3 px-4 py-2 text-sm font-medium text-red-300 hover:text-red-100 hover:bg-red-500/20 rounded-lg transition-colors">
                <i class="fa-solid fa-right-from-bracket w-5"></i>
                Keluar Sistem
            </a>
        </div>
    </aside>

    <!-- 2. MAIN CONTENT -->
    <main class="flex-1 flex flex-col min-w-0 overflow-hidden relative">
        
        <!-- Header -->
        <header class="h-16 bg-white border-b border-gray-200 flex items-center justify-between px-8 shadow-sm z-10">
            <nav class="flex" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2">
                    <li><a href="admin_panel.html" class="text-gray-400 hover:text-gray-500"><i class="fa-solid fa-house"></i></a></li>
                    <li><span class="text-gray-300">/</span></li>
                    <li><span class="text-sm font-medium text-primary">Kategori Layanan</span></li>
                </ol>
            </nav>

            <div class="flex items-center gap-3">
                <div class="text-right hidden md:block">
                    <p class="text-sm font-medium text-gray-900">Administrator Utama</p>
                    <p class="text-xs text-gray-500">Super Admin</p>
                </div>
                <img class="h-9 w-9 rounded-full bg-gray-300" src="https://ui-avatars.com/api/?name=Admin+Utama&background=random" alt="">
            </div>
        </header>

        <!-- Content Body -->
        <div class="flex-1 overflow-auto p-8">
            <div class="max-w-7xl mx-auto space-y-6">
                
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                    <div>
                        <h1 class="text-2xl font-bold text-gray-900">Pengaturan Layanan</h1>
                        <p class="text-sm text-gray-500 mt-1">Kelola jenis layanan, kode antrean, dan estimasi waktu.</p>
                    </div>
                    <button onclick="toggleModal('add-service-modal')" class="bg-primary hover:bg-primary-dark text-white px-5 py-2.5 rounded-lg shadow-lg hover:shadow-xl transition-all flex items-center gap-2 font-medium">
                        <i class="fa-solid fa-plus"></i>
                        Tambah Layanan Baru
                    </button>
                </div>

                <!-- Info Card -->
                <div class="bg-blue-50 border border-blue-100 rounded-lg p-4 flex gap-3 text-sm text-blue-800">
                    <i class="fa-solid fa-circle-info mt-0.5"></i>
                    <p>Layanan yang dinonaktifkan tidak akan muncul di Kiosk Warga, tetapi data riwayat antrean tetap tersimpan.</p>
                </div>

                <!-- Services List (Card Style for better description view) -->
                <div class="grid grid-cols-1 gap-4">
                    
                    <!-- Item 1: e-KTP -->
                    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow flex items-start justify-between group">
                        <div class="flex gap-5 items-start">
                            <div class="w-14 h-14 bg-blue-100 text-primary rounded-xl flex flex-col items-center justify-center font-bold border border-blue-200">
                                <span class="text-xs uppercase">Kode</span>
                                <span class="text-2xl">A</span>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 text-lg">Pembuatan e-KTP</h3>
                                <p class="text-sm text-gray-500 mt-1 max-w-2xl">Layanan perekaman biometrik dan pencetakan KTP elektronik baru atau penggantian.</p>
                                <div class="flex items-center gap-4 mt-3 text-xs font-medium text-gray-500">
                                    <span class="flex items-center gap-1 bg-gray-100 px-2 py-1 rounded"><i class="fa-regular fa-clock"></i> Est. 15 Menit/org</span>
                                    <span class="flex items-center gap-1 bg-gray-100 px-2 py-1 rounded"><i class="fa-solid fa-window-maximize"></i> Loket 1, 2</span>
                                </div>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <!-- Toggle Switch Mockup -->
                            <div class="flex items-center gap-2">
                                <span class="text-xs font-medium text-gray-500">Aktif</span>
                                <div class="relative inline-block w-10 align-middle select-none transition duration-200 ease-in">
                                    <input type="checkbox" name="toggle" id="toggle1" class="toggle-checkbox absolute block w-5 h-5 rounded-full bg-white border-4 appearance-none cursor-pointer border-gray-300" checked/>
                                    <label for="toggle1" class="toggle-label block overflow-hidden h-5 rounded-full bg-gray-300 cursor-pointer"></label>
                                </div>
                            </div>
                            <div class="h-8 w-px bg-gray-200 mx-2"></div>
                            <button class="text-gray-400 hover:text-primary transition-colors p-2 rounded hover:bg-blue-50" title="Edit"><i class="fa-solid fa-pen-to-square text-lg"></i></button>
                            <button onclick="confirmDelete('Pembuatan e-KTP')" class="text-gray-400 hover:text-red-500 transition-colors p-2 rounded hover:bg-red-50" title="Hapus"><i class="fa-solid fa-trash-can text-lg"></i></button>
                        </div>
                    </div>

                    <!-- Item 2: Kartu Keluarga -->
                    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm hover:shadow-md transition-shadow flex items-start justify-between group">
                        <div class="flex gap-5 items-start">
                            <div class="w-14 h-14 bg-amber-100 text-amber-700 rounded-xl flex flex-col items-center justify-center font-bold border border-amber-200">
                                <span class="text-xs uppercase">Kode</span>
                                <span class="text-2xl">B</span>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-900 text-lg">Kartu Keluarga (KK)</h3>
                                <p class="text-sm text-gray-500 mt-1 max-w-2xl">Pembuatan KK baru, penambahan anggota keluarga, atau pecah KK.</p>
                                <div class="flex items-center gap-4 mt-3 text-xs font-medium text-gray-500">
                                    <span class="flex items-center gap-1 bg-gray-100 px-2 py-1 rounded"><i class="fa-regular fa-clock"></i> Est. 20 Menit/org</span>
                                    <span class="flex items-center gap-1 bg-gray-100 px-2 py-1 rounded"><i class="fa-solid fa-window-maximize"></i> Loket 3</span>
                                </div>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="flex items-center gap-2">
                                <span class="text-xs font-medium text-gray-500">Aktif</span>
                                <div class="relative inline-block w-10 align-middle select-none transition duration-200 ease-in">
                                    <input type="checkbox" name="toggle" id="toggle2" class="toggle-checkbox absolute block w-5 h-5 rounded-full bg-white border-4 appearance-none cursor-pointer border-gray-300" checked/>
                                    <label for="toggle2" class="toggle-label block overflow-hidden h-5 rounded-full bg-gray-300 cursor-pointer"></label>
                                </div>
                            </div>
                            <div class="h-8 w-px bg-gray-200 mx-2"></div>
                            <button class="text-gray-400 hover:text-primary transition-colors p-2"><i class="fa-solid fa-pen-to-square text-lg"></i></button>
                            <button onclick="confirmDelete('Kartu Keluarga')" class="text-gray-400 hover:text-red-500 transition-colors p-2"><i class="fa-solid fa-trash-can text-lg"></i></button>
                        </div>
                    </div>

                     <!-- Item 3: Akta Kelahiran (Disabled Example) -->
                     <div class="bg-gray-50 border border-gray-200 rounded-xl p-5 shadow-sm flex items-start justify-between opacity-80">
                        <div class="flex gap-5 items-start">
                            <div class="w-14 h-14 bg-gray-200 text-gray-500 rounded-xl flex flex-col items-center justify-center font-bold border border-gray-300">
                                <span class="text-xs uppercase">Kode</span>
                                <span class="text-2xl">C</span>
                            </div>
                            <div>
                                <h3 class="font-bold text-gray-700 text-lg">Akta Kelahiran</h3>
                                <p class="text-sm text-gray-500 mt-1 max-w-2xl">Legalisir dan penerbitan akta kelahiran baru.</p>
                                <div class="flex items-center gap-4 mt-3 text-xs font-medium text-gray-500">
                                    <span class="flex items-center gap-1 bg-white border border-gray-200 px-2 py-1 rounded"><i class="fa-regular fa-clock"></i> Est. 10 Menit/org</span>
                                </div>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="flex items-center gap-2">
                                <span class="text-xs font-medium text-gray-400">Non-Aktif</span>
                                <div class="relative inline-block w-10 align-middle select-none transition duration-200 ease-in">
                                    <input type="checkbox" name="toggle" id="toggle3" class="toggle-checkbox absolute block w-5 h-5 rounded-full bg-white border-4 appearance-none cursor-pointer border-gray-300"/>
                                    <label for="toggle3" class="toggle-label block overflow-hidden h-5 rounded-full bg-gray-300 cursor-pointer"></label>
                                </div>
                            </div>
                            <div class="h-8 w-px bg-gray-200 mx-2"></div>
                            <button class="text-gray-400 hover:text-primary transition-colors p-2"><i class="fa-solid fa-pen-to-square text-lg"></i></button>
                            <button onclick="confirmDelete('Akta Kelahiran')" class="text-gray-400 hover:text-red-500 transition-colors p-2"><i class="fa-solid fa-trash-can text-lg"></i></button>
                        </div>
                    </div>

                </div>

            </div>
        </div>
    </main>

    <!-- 3. ADD SERVICE MODAL -->
    <div id="add-service-modal" class="modal opacity-0 pointer-events-none fixed w-full h-full top-0 left-0 flex items-center justify-center z-50">
        <div class="modal-overlay absolute w-full h-full bg-gray-900 opacity-50" onclick="toggleModal('add-service-modal')"></div>
        
        <div class="modal-container bg-white w-11/12 md:max-w-lg mx-auto rounded-xl shadow-2xl z-50 overflow-y-auto transform scale-95 transition-transform duration-300">
            
            <div class="modal-content py-4 text-left px-6 border-b border-gray-100 flex justify-between items-center">
                <h3 class="text-xl font-bold text-gray-900">Tambah Layanan Baru</h3>
                <div class="cursor-pointer" onclick="toggleModal('add-service-modal')">
                    <i class="fa-solid fa-xmark text-gray-500 hover:text-gray-700 text-lg"></i>
                </div>
            </div>

            <form id="addServiceForm" onsubmit="saveService(event)" class="px-6 py-6 space-y-4">
                
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Nama Layanan</label>
                    <input type="text" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent text-sm" placeholder="Contoh: Legalisir Dokumen">
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Kode Prefix</label>
                        <input type="text" required maxlength="1" style="text-transform:uppercase" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent text-sm uppercase" placeholder="A-Z">
                        <p class="text-xs text-gray-400 mt-1">1 Huruf (A, B, C...)</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Estimasi Waktu</label>
                        <div class="relative">
                            <input type="number" required class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent text-sm" placeholder="15">
                            <span class="absolute right-3 top-2 text-xs text-gray-400">Menit</span>
                        </div>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Deskripsi Singkat</label>
                    <textarea rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent text-sm" placeholder="Penjelasan singkat tentang layanan ini..."></textarea>
                </div>

                <!-- Footer -->
                <div class="pt-4 flex justify-end gap-3">
                    <button type="button" onclick="toggleModal('add-service-modal')" class="px-4 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-lg hover:bg-gray-50 transition-colors">Batal</button>
                    <button type="submit" class="px-4 py-2 bg-primary text-white text-sm font-medium rounded-lg hover:bg-primary-dark shadow-md hover:shadow-lg transition-all flex items-center gap-2">
                        <i class="fa-solid fa-save"></i> Simpan Layanan
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function toggleModal(modalID) {
            const modal = document.getElementById(modalID);
            const body = document.querySelector('body');
            const container = modal.querySelector('.modal-container');

            if(modal.classList.contains('opacity-0')) {
                modal.classList.remove('opacity-0', 'pointer-events-none');
                body.classList.add('modal-active');
                setTimeout(() => {
                    container.classList.remove('scale-95');
                    container.classList.add('scale-100');
                }, 10);
            } else {
                container.classList.remove('scale-100');
                container.classList.add('scale-95');
                setTimeout(() => {
                    modal.classList.add('opacity-0', 'pointer-events-none');
                    body.classList.remove('modal-active');
                }, 200);
            }
        }

        function confirmDelete(serviceName) {
            if(confirm('PERINGATAN: Menghapus layanan "' + serviceName + '" akan menghilangkan opsi ini dari Kiosk. Lanjutkan?')) {
                alert('Layanan berhasil dihapus.');
            }
        }

        function saveService(e) {
            e.preventDefault();
            const btn = e.target.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Menyimpan...';
            
            setTimeout(() => {
                alert('Kategori layanan baru berhasil ditambahkan!');
                toggleModal('add-service-modal');
                btn.innerHTML = originalText;
                e.target.reset();
            }, 800);
        }
    </script>
</body>
</html>